{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "HyperV.Agent": "Debug",
      "HyperV.Core": "Debug"
    },
    "LogToConsole": true,
    "LogToFile": true,
    "LogFilePath": "logs/hyperv-agent-remote.log"
  },
  "AllowedHosts": "*",
  "RemoteDebugging": {
    "Enabled": true,
    "RemoteHost": "192.168.7.63",
    "LocalHost": "0.0.0.0",
    "Port": 8743,
    "Environment": "Development"
  },
  "HyperV": {
    "EnableDetailedLogging": true,
    "LogWmiQueries": true,
    "LogHcsOperations": true,
    "LogHcnOperations": true,
    "EnablePerformanceCounters": true
  },
  "CORS": {
    "AllowAnyOrigin": true,
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:8080",
      "http://localhost:4200",
      "http://192.168.7.63:8743",
      "http://management.hyperv.local",
      "https://management.hyperv.local"
    ]
  }
}
