@page "/agents"
@inject CentralApiClient Api
@inject AuthSession Session

<PageTitle>Agents</PageTitle>

<h2>Agents</h2>

@if (string.IsNullOrWhiteSpace(Session.Token))
{
    <div class="alert alert-warning">Login required to load agents.</div>
}
else if (agents.Count == 0)
{
    <div class="alert alert-info">No agents registered yet.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Hostname</th>
                <th>API URL</th>
                <th>Type</th>
                <th>Status</th>
                <th>Last Seen (UTC)</th>
                <th>Cluster</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var agent in agents)
        {
            <tr>
                <td><a href="agents/@agent.Id">@agent.Hostname</a></td>
                <td>@agent.ApiBaseUrl</td>
                <td>@agent.HostType</td>
                <td>@agent.Status</td>
                <td>@agent.LastSeenUtc</td>
                <td>@agent.ClusterName</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private List<HyperV.CentralManagement.Models.AgentHost> agents = new();

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(Session.Token))
        {
            agents = (await Api.GetAgentsAsync()).ToList();
        }
    }
}
