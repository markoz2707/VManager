@page "/audit"
@inject CentralApiClient Api
@inject AuthSession Session

<PageTitle>Audit</PageTitle>

<h2>Audit Logs</h2>

@if (string.IsNullOrWhiteSpace(Session.Token))
{
    <div class="alert alert-warning">Login required.</div>
}
else if (logs.Count == 0)
{
    <div class="alert alert-info">No audit logs available.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Timestamp (UTC)</th>
                <th>User</th>
                <th>Action</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var log in logs)
        {
            <tr>
                <td>@log.TimestampUtc</td>
                <td>@log.Username</td>
                <td>@log.Action</td>
                <td>@log.Details</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private List<AuditLog> logs = new();

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(Session.Token))
        {
            logs = (await Api.GetAuditLogsAsync()).ToList();
        }
    }
}
