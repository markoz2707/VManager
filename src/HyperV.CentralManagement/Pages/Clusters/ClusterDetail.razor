@page "/clusters/{Id:guid}"
@implements IAsyncDisposable
@inject CentralApiClient Api
@inject AuthSession Session
@inject NavigationManager Nav
@inject SignalRClientService SignalR

<PageTitle>VManager - Cluster Details</PageTitle>

@if (loading)
{
    <div class="vm-loading">
        <div class="spinner-border spinner-border-sm" role="status"></div>
        <span>Loading cluster details...</span>
    </div>
}
else if (cluster == null)
{
    <div class="vm-empty-state">
        <i class="bi bi-exclamation-circle"></i>
        <p>Cluster not found.</p>
        <a href="/clusters" class="btn btn-primary">Back to Clusters</a>
    </div>
}
else
{
    <div class="vm-page-header">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1" style="font-size:0.8rem;">
                    <li class="breadcrumb-item"><a href="/clusters">Clusters</a></li>
                    <li class="breadcrumb-item active">@cluster.Name</li>
                </ol>
            </nav>
            <h2><i class="bi bi-diagram-3 me-2 text-primary"></i> @cluster.Name</h2>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary btn-sm" @onclick="() => showAddNodeModal = true">
                <i class="bi bi-plus-lg"></i> Add Node
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(cluster.Description))
    {
        <p class="text-muted mb-3">@cluster.Description</p>
    }

    <!-- Tabs -->
    <div class="vm-tabs">
        <button class="vm-tab @(activeTab == "nodes" ? "active" : "")" @onclick="ShowNodes">
            <i class="bi bi-hdd-network me-1"></i> Nodes (@cluster.Nodes.Count)
        </button>
        <button class="vm-tab @(activeTab == "ha" ? "active" : "")" @onclick="ShowHa">
            <i class="bi bi-shield-check me-1"></i> HA
        </button>
        <button class="vm-tab @(activeTab == "drs" ? "active" : "")" @onclick="ShowDrs">
            <i class="bi bi-sliders me-1"></i> DRS
        </button>
    </div>

    @if (activeTab == "nodes")
    {
        @if (cluster.Nodes.Count == 0)
        {
            <div class="vm-empty-state">
                <i class="bi bi-hdd-network"></i>
                <p>No nodes in this cluster. Add agent hosts to begin.</p>
            </div>
        }
        else
        {
            <div class="vm-table">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Hostname</th>
                            <th>Status</th>
                            <th>Host Type</th>
                            <th>API URL</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var node in cluster.Nodes)
                        {
                            <tr>
                                <td>
                                    <a href="/agents/@node.AgentHostId">
                                        @(node.AgentHost?.Hostname ?? node.AgentHostId.ToString()[..8])
                                    </a>
                                </td>
                                <td>
                                    @if (node.AgentHost != null)
                                    {
                                        <span class="status-dot @GetStatusClass(node.AgentHost.Status)"></span>
                                        @node.AgentHost.Status
                                    }
                                </td>
                                <td>@(node.AgentHost?.HostType ?? "-")</td>
                                <td style="font-size:0.8rem;" class="text-muted">@(node.AgentHost?.ApiBaseUrl ?? "-")</td>
                                <td>
                                    <button class="btn btn-outline-danger btn-action" @onclick="() => RemoveNode(node.Id)" title="Remove">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
    else if (activeTab == "ha")
    {
        <div class="vm-card mt-2">
            <div class="vm-card-body text-center py-4">
                <i class="bi bi-shield-check" style="font-size:2rem; color:#0d6efd;"></i>
                <p class="mt-2 mb-2">High Availability configuration for this cluster.</p>
                <a href="/ha/@Id" class="btn btn-primary btn-sm">Configure HA</a>
            </div>
        </div>
    }
    else if (activeTab == "drs")
    {
        <div class="vm-card mt-2">
            <div class="vm-card-body text-center py-4">
                <i class="bi bi-sliders" style="font-size:2rem; color:#0d6efd;"></i>
                <p class="mt-2 mb-2">Distributed Resource Scheduler for this cluster.</p>
                <a href="/drs/@Id" class="btn btn-primary btn-sm">Configure DRS</a>
            </div>
        </div>
    }
}

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger mt-3" style="font-size:0.85rem;">@error</div>
}

@if (showAddNodeModal)
{
    <div class="vm-modal-backdrop" @onclick="() => showAddNodeModal = false">
        <div class="vm-modal" @onclick:stopPropagation="true" style="max-width:400px;">
            <div class="vm-modal-header">
                <h5>Add Node to Cluster</h5>
                <button class="btn-close" @onclick="() => showAddNodeModal = false"></button>
            </div>
            <div class="vm-modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Select Agent Host</label>
                    <select class="form-select" @bind="selectedAgentId">
                        <option value="">-- Select Host --</option>
                        @foreach (var a in availableAgents)
                        {
                            <option value="@a.Id">@a.Hostname (@a.Status)</option>
                        }
                    </select>
                </div>
            </div>
            <div class="vm-modal-footer">
                <button class="btn btn-secondary" @onclick="() => showAddNodeModal = false">Cancel</button>
                <button class="btn btn-primary" @onclick="AddNode">Add</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool loading = true;
    private Cluster? cluster;
    private List<AgentHost> allAgents = new();
    private string activeTab = "nodes";
    private string error = string.Empty;

    private bool showAddNodeModal;
    private string selectedAgentId = string.Empty;

    private void ShowNodes() { activeTab = "nodes"; }
    private void ShowHa() { activeTab = "ha"; }
    private void ShowDrs() { activeTab = "drs"; }

    private IEnumerable<AgentHost> availableAgents =>
        allAgents.Where(a => cluster?.Nodes.All(n => n.AgentHostId != a.Id) ?? true);

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Session.Token)) { Nav.NavigateTo("/login"); return; }
        await LoadData();
        SignalR.OnAgentStatusChanged += _ => InvokeAsync(LoadData);
        await SignalR.StartAsync();
        await SignalR.JoinClusterGroupAsync(Id);
    }

    public async ValueTask DisposeAsync()
    {
        SignalR.OnAgentStatusChanged -= _ => InvokeAsync(LoadData);
    }

    private async Task LoadData()
    {
        loading = true;
        try
        {
            cluster = await Api.GetClusterAsync(Id);
            allAgents = (await Api.GetAgentsAsync()).ToList();
        }
        catch (Exception ex) { error = ex.Message; }
        finally { loading = false; }
    }

    private async Task AddNode()
    {
        if (string.IsNullOrWhiteSpace(selectedAgentId)) return;
        try
        {
            await Api.AddClusterNodeAsync(Id, new { agentHostId = Guid.Parse(selectedAgentId) });
            showAddNodeModal = false;
            selectedAgentId = string.Empty;
            await LoadData();
        }
        catch (Exception ex) { error = ex.Message; }
    }

    private async Task RemoveNode(Guid nodeId)
    {
        try
        {
            await Api.RemoveClusterNodeAsync(Id, nodeId);
            await LoadData();
        }
        catch (Exception ex) { error = ex.Message; }
    }

    private string GetStatusClass(AgentStatus status) => status switch
    {
        AgentStatus.Online => "online",
        AgentStatus.Offline => "offline",
        _ => "unknown"
    };
}
