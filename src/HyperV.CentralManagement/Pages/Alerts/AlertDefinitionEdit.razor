@page "/alerts/new"
@page "/alerts/{Id:guid}"
@inject CentralApiClient Api
@inject AuthSession Session
@inject NavigationManager Nav

<PageTitle>VManager - @(isNew ? "Create" : "Edit") Alert Rule</PageTitle>

<div class="vm-page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1" style="font-size:0.8rem;">
                <li class="breadcrumb-item"><a href="/alerts">Alerts</a></li>
                <li class="breadcrumb-item active">@(isNew ? "New Rule" : "Edit Rule")</li>
            </ol>
        </nav>
        <h2>@(isNew ? "Create" : "Edit") Alert Rule</h2>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="vm-card">
            <div class="vm-card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Name</label>
                        <input class="form-control" @bind="model.Name" placeholder="e.g. High CPU Usage" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Metric Name</label>
                        <select class="form-select" @bind="model.MetricName">
                            <option value="">-- Select Metric --</option>
                            <option value="host_cpu_usage">Host CPU Usage</option>
                            <option value="host_memory_usage">Host Memory Usage</option>
                            <option value="vm_cpu_usage">VM CPU Usage</option>
                            <option value="vm_memory_usage">VM Memory Usage</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea class="form-control" @bind="model.Description" rows="2"></textarea>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Condition</label>
                        <select class="form-select" @bind="model.Condition">
                            <option value="0">Greater Than</option>
                            <option value="1">Less Than</option>
                            <option value="2">Equals</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Threshold Value</label>
                        <input type="number" class="form-control" @bind="model.ThresholdValue" step="0.1" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Severity</label>
                        <select class="form-select" @bind="model.Severity">
                            <option value="0">Info</option>
                            <option value="1">Warning</option>
                            <option value="2">Critical</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Evaluation Periods</label>
                        <input type="number" class="form-control" @bind="model.EvaluationPeriods" min="1" max="10" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Cooldown (seconds)</label>
                        <input type="number" class="form-control" @bind="model.CooldownSeconds" min="60" max="3600" />
                    </div>
                    <div class="col-md-4">
                        <div class="form-check mt-4">
                            <input class="form-check-input" type="checkbox" @bind="model.IsEnabled" id="alertEnabled" />
                            <label class="form-check-label" for="alertEnabled">Enabled</label>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="mt-3">
                    <button class="btn btn-primary" @onclick="Save" disabled="@saving">
                        @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-check-lg"></i> @(isNew ? "Create" : "Save")
                    </button>
                    <a href="/alerts" class="btn btn-secondary ms-2">Cancel</a>
                </div>

                @if (!string.IsNullOrWhiteSpace(successMsg))
                {
                    <div class="alert alert-success mt-3 py-2" style="font-size:0.85rem;">@successMsg</div>
                }
                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <div class="alert alert-danger mt-3 py-2" style="font-size:0.85rem;">@error</div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="vm-card">
            <div class="vm-card-header">
                <h6><i class="bi bi-info-circle me-2"></i>Help</h6>
            </div>
            <div class="vm-card-body" style="font-size:0.85rem;">
                <p><strong>Metric Name:</strong> The metric to monitor. Host-level metrics start with <code>host_</code> and VM-level with <code>vm_</code>.</p>
                <p><strong>Condition:</strong> When the metric value satisfies this condition relative to the threshold, the alert fires.</p>
                <p><strong>Evaluation Periods:</strong> How many consecutive evaluation cycles the condition must be true before firing.</p>
                <p><strong>Cooldown:</strong> Minimum seconds between re-fires of the same alert.</p>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool isNew => Id == null || Id == Guid.Empty;
    private bool saving;
    private AlertDefModel model = new();
    private string error = string.Empty;
    private string successMsg = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Session.Token)) { Nav.NavigateTo("/login"); return; }

        if (!isNew)
        {
            try
            {
                var def = await Api.GetAlertDefinitionAsync(Id!.Value);
                if (def != null)
                {
                    model = new AlertDefModel
                    {
                        Name = def.Name,
                        Description = def.Description,
                        MetricName = def.MetricName,
                        Condition = (int)def.Condition,
                        ThresholdValue = def.ThresholdValue,
                        Severity = (int)def.Severity,
                        EvaluationPeriods = def.EvaluationPeriods,
                        CooldownSeconds = def.CooldownSeconds,
                        IsEnabled = def.IsEnabled
                    };
                }
            }
            catch (Exception ex) { error = ex.Message; }
        }
    }

    private async Task Save()
    {
        error = string.Empty; successMsg = string.Empty;
        if (string.IsNullOrWhiteSpace(model.Name) || string.IsNullOrWhiteSpace(model.MetricName))
        {
            error = "Name and Metric are required.";
            return;
        }
        saving = true;
        try
        {
            var payload = new
            {
                name = model.Name,
                description = model.Description,
                metricName = model.MetricName,
                condition = model.Condition,
                thresholdValue = model.ThresholdValue,
                severity = model.Severity,
                evaluationPeriods = model.EvaluationPeriods,
                cooldownSeconds = model.CooldownSeconds,
                isEnabled = model.IsEnabled
            };

            HttpResponseMessage response;
            if (isNew)
                response = await Api.CreateAlertDefinitionAsync(payload);
            else
                response = await Api.UpdateAlertDefinitionAsync(Id!.Value, payload);

            if (response.IsSuccessStatusCode)
            {
                if (isNew) Nav.NavigateTo("/alerts");
                else successMsg = "Alert rule saved.";
            }
            else error = "Save failed.";
        }
        catch (Exception ex) { error = ex.Message; }
        finally { saving = false; }
    }

    private class AlertDefModel
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string MetricName { get; set; } = string.Empty;
        public int Condition { get; set; }
        public double ThresholdValue { get; set; }
        public int Severity { get; set; } = 1;
        public int EvaluationPeriods { get; set; } = 1;
        public int CooldownSeconds { get; set; } = 300;
        public bool IsEnabled { get; set; } = true;
    }
}
