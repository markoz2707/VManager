@page "/notifications"
@inject CentralApiClient Api
@inject AuthSession Session
@inject NavigationManager Nav

<PageTitle>VManager - Notification Channels</PageTitle>

<div class="vm-page-header">
    <h2>Notification Channels</h2>
    <button class="btn btn-primary btn-sm" @onclick="() => { showModal = true; editId = null; ResetForm(); }">
        <i class="bi bi-plus-lg"></i> Create Channel
    </button>
</div>

@if (loading)
{
    <div class="vm-loading">
        <div class="spinner-border spinner-border-sm" role="status"></div>
        <span>Loading channels...</span>
    </div>
}
else if (channels.Count == 0)
{
    <div class="vm-empty-state">
        <i class="bi bi-megaphone"></i>
        <p>No notification channels configured. Create one to receive alert notifications.</p>
    </div>
}
else
{
    <div class="vm-table">
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ch in channels)
                {
                    <tr>
                        <td class="fw-semibold">
                            <i class="bi @GetTypeIcon(ch.Type) me-1"></i> @ch.Name
                        </td>
                        <td><span class="badge bg-primary-subtle text-primary" style="font-size:0.75rem;">@ch.Type</span></td>
                        <td>
                            @if (ch.IsEnabled)
                            {
                                <span class="status-badge running">Active</span>
                            }
                            else
                            {
                                <span class="status-badge off">Disabled</span>
                            }
                        </td>
                        <td style="font-size:0.8rem;" class="text-muted">@ch.CreatedUtc.ToString("yyyy-MM-dd")</td>
                        <td>
                            <div class="d-flex gap-1">
                                <button class="btn btn-outline-info btn-action" @onclick="() => TestChannel(ch.Id)" title="Test">
                                    <i class="bi bi-send"></i>
                                </button>
                                <button class="btn btn-outline-primary btn-action" @onclick="() => EditChannel(ch)" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-outline-danger btn-action" @onclick="() => DeleteChannel(ch.Id)" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger mt-3" style="font-size:0.85rem;">@error</div>
}
@if (!string.IsNullOrWhiteSpace(successMsg))
{
    <div class="alert alert-success mt-3" style="font-size:0.85rem;">@successMsg</div>
}

@if (showModal)
{
    <div class="vm-modal-backdrop" @onclick="() => showModal = false">
        <div class="vm-modal" @onclick:stopPropagation="true">
            <div class="vm-modal-header">
                <h5>@(editId == null ? "Create" : "Edit") Notification Channel</h5>
                <button class="btn-close" @onclick="() => showModal = false"></button>
            </div>
            <div class="vm-modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Name</label>
                    <input class="form-control" @bind="formName" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Type</label>
                    <select class="form-select" @bind="formType">
                        <option value="0">Email</option>
                        <option value="1">Webhook</option>
                        <option value="2">Slack</option>
                        <option value="3">MS Teams</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Configuration (JSON)</label>
                    <textarea class="form-control font-monospace" @bind="formConfig" rows="4" style="font-size:0.8rem;"></textarea>
                    <small class="text-muted">E.g. for webhook: {"url": "https://..."}</small>
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" @bind="formEnabled" id="chEnabled" />
                    <label class="form-check-label" for="chEnabled">Enabled</label>
                </div>
                @if (!string.IsNullOrWhiteSpace(modalError))
                {
                    <div class="alert alert-danger py-2" style="font-size:0.85rem;">@modalError</div>
                }
            </div>
            <div class="vm-modal-footer">
                <button class="btn btn-secondary" @onclick="() => showModal = false">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveChannel">
                    @(editId == null ? "Create" : "Save")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private List<NotificationChannel> channels = new();
    private string error = string.Empty;
    private string successMsg = string.Empty;

    private bool showModal;
    private Guid? editId;
    private string formName = string.Empty;
    private int formType;
    private string formConfig = "{}";
    private bool formEnabled = true;
    private string modalError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Session.Token)) { Nav.NavigateTo("/login"); return; }
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        try { channels = (await Api.GetNotificationChannelsAsync()).ToList(); }
        catch (Exception ex) { error = ex.Message; }
        finally { loading = false; }
    }

    private void ResetForm()
    {
        formName = string.Empty;
        formType = 0;
        formConfig = "{}";
        formEnabled = true;
        modalError = string.Empty;
    }

    private void EditChannel(NotificationChannel ch)
    {
        editId = ch.Id;
        formName = ch.Name;
        formType = (int)ch.Type;
        formConfig = ch.Configuration;
        formEnabled = ch.IsEnabled;
        modalError = string.Empty;
        showModal = true;
    }

    private async Task SaveChannel()
    {
        modalError = string.Empty;
        if (string.IsNullOrWhiteSpace(formName)) { modalError = "Name is required."; return; }
        try
        {
            var payload = new { name = formName, type = formType, configuration = formConfig, isEnabled = formEnabled };
            HttpResponseMessage response;
            if (editId == null)
                response = await Api.CreateNotificationChannelAsync(payload);
            else
                response = await Api.UpdateNotificationChannelAsync(editId.Value, payload);

            if (response.IsSuccessStatusCode)
            {
                showModal = false;
                await LoadData();
            }
            else { modalError = "Save failed."; }
        }
        catch (Exception ex) { modalError = ex.Message; }
    }

    private async Task DeleteChannel(Guid id)
    {
        error = string.Empty;
        try { await Api.DeleteNotificationChannelAsync(id); await LoadData(); }
        catch (Exception ex) { error = ex.Message; }
    }

    private async Task TestChannel(Guid id)
    {
        successMsg = string.Empty; error = string.Empty;
        try
        {
            var response = await Api.TestNotificationChannelAsync(id);
            successMsg = response.IsSuccessStatusCode ? "Test notification sent." : "Test failed.";
        }
        catch (Exception ex) { error = ex.Message; }
    }

    private string GetTypeIcon(NotificationChannelType type) => type switch
    {
        NotificationChannelType.Email => "bi-envelope",
        NotificationChannelType.Webhook => "bi-globe",
        NotificationChannelType.Slack => "bi-chat-dots",
        NotificationChannelType.MsTeams => "bi-microsoft-teams",
        _ => "bi-megaphone"
    };
}
