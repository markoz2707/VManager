@page "/roles"
@inject CentralApiClient Api
@inject AuthSession Session
@inject NavigationManager Nav

<PageTitle>VManager - Roles</PageTitle>

<div class="vm-page-header">
    <h2>Role Management</h2>
    <button class="btn btn-primary btn-sm" @onclick="() => showCreateModal = true">
        <i class="bi bi-plus-lg"></i> Create Role
    </button>
</div>

@if (loading)
{
    <div class="vm-loading">
        <div class="spinner-border spinner-border-sm" role="status"></div>
        <span>Loading roles...</span>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var role in roles)
        {
            <div class="col-md-6 col-xl-4">
                <div class="vm-card">
                    <div class="vm-card-header">
                        <h6>
                            <i class="bi bi-shield-lock me-2 text-primary"></i>@role.Name
                            @if (role.IsBuiltIn)
                            {
                                <span class="badge bg-secondary-subtle text-secondary ms-2" style="font-size:0.65rem;">Built-in</span>
                            }
                        </h6>
                        <div class="d-flex gap-1">
                            @if (!role.IsBuiltIn)
                            {
                                <a href="/roles/@role.Id" class="btn btn-outline-primary btn-action" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button class="btn btn-outline-danger btn-action" @onclick="() => DeleteRole(role.Id)" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                            else
                            {
                                <a href="/roles/@role.Id" class="btn btn-outline-primary btn-action" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                            }
                        </div>
                    </div>
                    <div class="vm-card-body">
                        <p class="text-muted mb-2" style="font-size:0.85rem;">@(role.Description ?? "No description")</p>
                        <div>
                            <span class="badge bg-primary-subtle text-primary me-1" style="font-size:0.7rem;">
                                @role.Permissions.Count permissions
                            </span>
                        </div>
                        @if (role.Permissions.Count > 0)
                        {
                            <div class="mt-2">
                                @foreach (var perm in role.Permissions.Take(5))
                                {
                                    <span class="badge bg-light text-dark me-1 mb-1" style="font-size:0.65rem;">
                                        @perm.Resource:@perm.Action
                                    </span>
                                }
                                @if (role.Permissions.Count > 5)
                                {
                                    <span class="text-muted" style="font-size:0.65rem;">+@(role.Permissions.Count - 5) more</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger mt-3" style="font-size:0.85rem;">@error</div>
}

@if (showCreateModal)
{
    <div class="vm-modal-backdrop" @onclick="() => showCreateModal = false">
        <div class="vm-modal" @onclick:stopPropagation="true">
            <div class="vm-modal-header">
                <h5>Create Role</h5>
                <button class="btn-close" @onclick="() => showCreateModal = false"></button>
            </div>
            <div class="vm-modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Name</label>
                    <input class="form-control" @bind="newRoleName" placeholder="e.g. VM Operator" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea class="form-control" @bind="newRoleDesc" rows="2"></textarea>
                </div>
                @if (!string.IsNullOrWhiteSpace(createError))
                {
                    <div class="alert alert-danger py-2" style="font-size:0.85rem;">@createError</div>
                }
            </div>
            <div class="vm-modal-footer">
                <button class="btn btn-secondary" @onclick="() => showCreateModal = false">Cancel</button>
                <button class="btn btn-primary" @onclick="CreateRole">Create</button>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private List<RoleDto> roles = new();
    private string error = string.Empty;

    private bool showCreateModal;
    private string createError = string.Empty;
    private string newRoleName = string.Empty;
    private string? newRoleDesc;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Session.Token)) { Nav.NavigateTo("/login"); return; }
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        try { roles = (await Api.GetRolesAsync()).ToList(); }
        catch (Exception ex) { error = ex.Message; }
        finally { loading = false; }
    }

    private async Task CreateRole()
    {
        createError = string.Empty;
        if (string.IsNullOrWhiteSpace(newRoleName)) { createError = "Name is required."; return; }
        try
        {
            var response = await Api.CreateRoleAsync(new { name = newRoleName, description = newRoleDesc });
            if (response.IsSuccessStatusCode)
            {
                showCreateModal = false;
                newRoleName = string.Empty;
                newRoleDesc = null;
                await LoadData();
            }
            else { createError = "Failed to create role."; }
        }
        catch (Exception ex) { createError = ex.Message; }
    }

    private async Task DeleteRole(Guid id)
    {
        error = string.Empty;
        try { await Api.DeleteRoleAsync(id); await LoadData(); }
        catch (Exception ex) { error = ex.Message; }
    }
}
