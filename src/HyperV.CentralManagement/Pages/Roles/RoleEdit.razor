@page "/roles/{Id:guid}"
@inject CentralApiClient Api
@inject AuthSession Session
@inject NavigationManager Nav

<PageTitle>VManager - Edit Role</PageTitle>

@if (loading)
{
    <div class="vm-loading">
        <div class="spinner-border spinner-border-sm" role="status"></div>
        <span>Loading role...</span>
    </div>
}
else if (role == null)
{
    <div class="vm-empty-state">
        <i class="bi bi-exclamation-circle"></i>
        <p>Role not found.</p>
        <a href="/roles" class="btn btn-primary">Back to Roles</a>
    </div>
}
else
{
    <div class="vm-page-header">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1" style="font-size:0.8rem;">
                    <li class="breadcrumb-item"><a href="/roles">Roles</a></li>
                    <li class="breadcrumb-item active">@role.Name</li>
                </ol>
            </nav>
            <h2>
                <i class="bi bi-shield-lock me-2 text-primary"></i>@role.Name
                @if (role.IsBuiltIn)
                {
                    <span class="badge bg-secondary ms-2" style="font-size:0.7rem;">Built-in (Read-Only)</span>
                }
            </h2>
        </div>
    </div>

    @if (!role.IsBuiltIn)
    {
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <div class="vm-card">
                    <div class="vm-card-header"><h6>Properties</h6></div>
                    <div class="vm-card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Name</label>
                            <input class="form-control" @bind="editName" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea class="form-control" @bind="editDesc" rows="2"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Permission Matrix -->
    <div class="vm-card">
        <div class="vm-card-header">
            <h6><i class="bi bi-key me-2"></i>Permission Matrix</h6>
            <span class="badge bg-primary">@selectedPermissionIds.Count selected</span>
        </div>
        <div class="vm-card-body">
            <div class="table-responsive">
                <table class="table table-bordered perm-matrix">
                    <thead>
                        <tr>
                            <th>Resource</th>
                            @foreach (var action in actions)
                            {
                                <th>@action</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var resource in resources)
                        {
                            <tr>
                                <td class="fw-semibold">@resource</td>
                                @foreach (var action in actions)
                                {
                                    var perm = allPermissions.FirstOrDefault(p =>
                                        p.Resource == resource && p.Action == action);
                                    <td>
                                        @if (perm != null)
                                        {
                                            <input type="checkbox" class="form-check-input"
                                                   checked="@selectedPermissionIds.Contains(perm.Id)"
                                                   disabled="@role.IsBuiltIn"
                                                   @onchange="e => TogglePerm(perm.Id, (bool)(e.Value ?? false))" />
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!role.IsBuiltIn)
            {
                <div class="mt-3">
                    <button class="btn btn-primary" @onclick="SaveRole" disabled="@saving">
                        @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-check-lg"></i> Save Role
                    </button>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(successMsg))
            {
                <div class="alert alert-success mt-3 py-2" style="font-size:0.85rem;">@successMsg</div>
            }
            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger mt-3 py-2" style="font-size:0.85rem;">@error</div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool loading = true;
    private bool saving;
    private RoleDto? role;
    private List<PermissionDto> allPermissions = new();
    private HashSet<Guid> selectedPermissionIds = new();

    private string editName = string.Empty;
    private string? editDesc;
    private string error = string.Empty;
    private string successMsg = string.Empty;

    private readonly string[] resources = { "vm", "host", "cluster", "network", "storage", "user", "audit", "datacenter", "content-library" };
    private readonly string[] actions = { "read", "create", "update", "delete", "power", "migrate", "snapshot" };

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Session.Token)) { Nav.NavigateTo("/login"); return; }
        loading = true;
        try
        {
            var roleTask = Api.GetRoleAsync(Id);
            var permTask = Api.GetPermissionsAsync();
            await Task.WhenAll(roleTask, permTask);

            role = await roleTask;
            allPermissions = (await permTask).ToList();

            if (role != null)
            {
                editName = role.Name;
                editDesc = role.Description;
                selectedPermissionIds = new HashSet<Guid>(role.Permissions.Select(p => p.Id));
            }
        }
        catch (Exception ex) { error = ex.Message; }
        finally { loading = false; }
    }

    private void TogglePerm(Guid id, bool isChecked)
    {
        if (isChecked) selectedPermissionIds.Add(id);
        else selectedPermissionIds.Remove(id);
    }

    private async Task SaveRole()
    {
        error = string.Empty; successMsg = string.Empty; saving = true;
        try
        {
            var response = await Api.UpdateRoleAsync(Id, new
            {
                name = editName,
                description = editDesc,
                permissionIds = selectedPermissionIds.ToList()
            });
            successMsg = response.IsSuccessStatusCode ? "Role saved." : "Failed to save role.";
        }
        catch (Exception ex) { error = ex.Message; }
        finally { saving = false; }
    }
}
