@page "/agents/{Id:guid}"
@inject CentralApiClient CentralApi
@inject AgentApiClient AgentApi
@inject AuthSession Session

<PageTitle>Agent Details</PageTitle>

@if (string.IsNullOrWhiteSpace(Session.Token))
{
    <div class="alert alert-warning">Login required.</div>
}
else if (agent == null)
{
    <div class="alert alert-info">Loading...</div>
}
else
{
    <h2>@agent.Hostname</h2>

    <dl class="row">
        <dt class="col-sm-3">API URL</dt>
        <dd class="col-sm-9">@agent.ApiBaseUrl</dd>
        <dt class="col-sm-3">Type</dt>
        <dd class="col-sm-9">@agent.HostType</dd>
        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@agent.Status</dd>
        <dt class="col-sm-3">Last Seen (UTC)</dt>
        <dd class="col-sm-9">@agent.LastSeenUtc</dd>
        <dt class="col-sm-3">Cluster</dt>
        <dd class="col-sm-9">@agent.ClusterName</dd>
    </dl>

    <button class="btn btn-outline-primary me-2" @onclick="CheckHealth">Check Health</button>
    <button class="btn btn-outline-secondary" @onclick="LoadVms">Load VMs</button>

    @if (!string.IsNullOrWhiteSpace(healthStatus))
    {
        <div class="alert alert-success mt-3">Agent health: @healthStatus</div>
    }

    @if (vms != null)
    {
        <div class="mt-3">
            <strong>VMs:</strong> HCS @vms.Hcs.Count, WMI @vms.Wmi.Count
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-danger mt-3">@error</div>
    }
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private AgentHost? agent;
    private string healthStatus = string.Empty;
    private string error = string.Empty;
    private VmListResponse? vms;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(Session.Token))
        {
            agent = await CentralApi.GetAgentAsync(Id);
        }
    }

    private async Task CheckHealth()
    {
        error = string.Empty;
        healthStatus = string.Empty;

        if (agent == null)
        {
            return;
        }

        try
        {
            var health = await AgentApi.GetHealthAsync(agent.ApiBaseUrl);
            healthStatus = health?.Status ?? "unknown";
        }
        catch (Exception ex)
        {
            error = $"Health check failed: {ex.Message}";
        }
    }

    private async Task LoadVms()
    {
        error = string.Empty;
        vms = null;

        if (agent == null)
        {
            return;
        }

        try
        {
            vms = await AgentApi.GetVmsAsync(agent.ApiBaseUrl);
        }
        catch (Exception ex)
        {
            error = $"VM load failed: {ex.Message}";
        }
    }
}
