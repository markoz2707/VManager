@page "/agents"
@implements IAsyncDisposable
@inject CentralApiClient Api
@inject AuthSession Session
@inject NavigationManager Nav
@inject SignalRClientService SignalR

<PageTitle>VManager - Agents</PageTitle>

<div class="vm-page-header">
    <h2>Agent Hosts</h2>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary btn-sm" @onclick="LoadData">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
        <button class="btn btn-primary btn-sm" @onclick="() => showRegisterModal = true">
            <i class="bi bi-plus-lg"></i> Register Agent
        </button>
    </div>
</div>

@if (loading)
{
    <div class="vm-loading">
        <div class="spinner-border spinner-border-sm" role="status"></div>
        <span>Loading agents...</span>
    </div>
}
else if (agents.Count == 0)
{
    <div class="vm-empty-state">
        <i class="bi bi-hdd-network"></i>
        <p>No agents registered yet. Register your first agent host to get started.</p>
        <button class="btn btn-primary" @onclick="() => showRegisterModal = true">
            <i class="bi bi-plus-lg"></i> Register Agent
        </button>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var agent in filteredAgents)
        {
            <div class="col-md-6 col-xl-4">
                <a href="/agents/@agent.Id" class="agent-card">
                    <div class="d-flex align-items-start justify-content-between mb-2">
                        <div class="d-flex align-items-center">
                            <span class="status-dot @GetStatusClass(agent.Status)"></span>
                            <span class="agent-hostname">@agent.Hostname</span>
                        </div>
                        <span class="badge bg-secondary-subtle text-secondary" style="font-size:0.7rem;">@agent.HostType</span>
                    </div>
                    <div class="agent-meta">
                        <div><i class="bi bi-link-45deg me-1"></i> @agent.ApiBaseUrl</div>
                        @if (!string.IsNullOrWhiteSpace(agent.IpAddress))
                        {
                            <div><i class="bi bi-ethernet me-1"></i> @agent.IpAddress</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(agent.ClusterName))
                        {
                            <div><i class="bi bi-diagram-3 me-1"></i> @agent.ClusterName</div>
                        }
                        <div class="mt-1">
                            <i class="bi bi-clock me-1"></i>
                            Last seen: @(agent.LastSeenUtc == DateTimeOffset.MinValue ? "Never" : agent.LastSeenUtc.ToString("yyyy-MM-dd HH:mm"))
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger mt-3">@error</div>
}

@if (showRegisterModal)
{
    <div class="vm-modal-backdrop" @onclick="() => showRegisterModal = false">
        <div class="vm-modal" @onclick:stopPropagation="true">
            <div class="vm-modal-header">
                <h5>Register Agent</h5>
                <button class="btn-close" @onclick="() => showRegisterModal = false"></button>
            </div>
            <div class="vm-modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Hostname</label>
                    <input class="form-control" @bind="newAgent.Hostname" placeholder="e.g. hyperv-host-01" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">API Base URL</label>
                    <input class="form-control" @bind="newAgent.ApiBaseUrl" placeholder="https://192.168.1.10:8743" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">IP Address</label>
                    <input class="form-control" @bind="newAgent.IpAddress" placeholder="192.168.1.10" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Host Type</label>
                    <select class="form-select" @bind="newAgent.HostType">
                        <option value="Hyper-V">Hyper-V</option>
                        <option value="KVM">KVM</option>
                    </select>
                </div>

                @if (!string.IsNullOrWhiteSpace(registerError))
                {
                    <div class="alert alert-danger py-2" style="font-size:0.85rem;">@registerError</div>
                }
            </div>
            <div class="vm-modal-footer">
                <button class="btn btn-secondary" @onclick="() => showRegisterModal = false">Cancel</button>
                <button class="btn btn-primary" @onclick="RegisterAgent" disabled="@registering">
                    @if (registering)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Register
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private List<AgentHost> agents = new();
    private List<AgentHost> filteredAgents => agents;
    private string error = string.Empty;

    private bool showRegisterModal;
    private bool registering;
    private string registerError = string.Empty;
    private NewAgentModel newAgent = new();

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Session.Token)) { Nav.NavigateTo("/login"); return; }
        await LoadData();
        SignalR.OnAgentStatusChanged += _ => InvokeAsync(LoadData);
        await SignalR.StartAsync();
    }

    public async ValueTask DisposeAsync()
    {
        SignalR.OnAgentStatusChanged -= _ => InvokeAsync(LoadData);
    }

    private async Task LoadData()
    {
        loading = true;
        error = string.Empty;
        try
        {
            agents = (await Api.GetAgentsAsync()).ToList();
        }
        catch (Exception ex)
        {
            error = $"Failed to load agents: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task RegisterAgent()
    {
        registerError = string.Empty;
        if (string.IsNullOrWhiteSpace(newAgent.Hostname) || string.IsNullOrWhiteSpace(newAgent.ApiBaseUrl))
        {
            registerError = "Hostname and API URL are required.";
            return;
        }

        registering = true;
        try
        {
            var response = await Api.RegisterAgentAsync(new
            {
                hostname = newAgent.Hostname,
                apiBaseUrl = newAgent.ApiBaseUrl,
                ipAddress = newAgent.IpAddress,
                hostType = newAgent.HostType
            });

            if (response.IsSuccessStatusCode)
            {
                showRegisterModal = false;
                newAgent = new();
                await LoadData();
            }
            else
            {
                registerError = "Failed to register agent. Check if the hostname is already in use.";
            }
        }
        catch (Exception ex)
        {
            registerError = $"Error: {ex.Message}";
        }
        finally
        {
            registering = false;
        }
    }

    private string GetStatusClass(AgentStatus status) => status switch
    {
        AgentStatus.Online => "online",
        AgentStatus.Offline => "offline",
        _ => "unknown"
    };

    private class NewAgentModel
    {
        public string Hostname { get; set; } = string.Empty;
        public string ApiBaseUrl { get; set; } = string.Empty;
        public string? IpAddress { get; set; }
        public string HostType { get; set; } = "Hyper-V";
    }
}
