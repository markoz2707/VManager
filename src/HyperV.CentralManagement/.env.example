# HyperV Central Management Configuration Template
# Copy this file to .env and fill in your values
# Environment variables override appsettings.json values

# Database Configuration
CONNECTIONSTRINGS__CENTRALDB=Host=localhost;Port=5432;Database=hyperv_central;Username=hyperv;Password=change-me

# JWT Configuration
JWT__SECRET=your-strong-secret-key-minimum-32-characters-long-change-this
JWT__ISSUER=hyperv-central
JWT__AUDIENCE=hyperv-central-ui
JWT__EXPIRATIONMINUTES=480

# Initial Admin Account (used only on first startup)
INITIALADMIN__USERNAME=admin
INITIALADMIN__PASSWORD=SecurePassword123!

# LDAP/Active Directory Configuration
LDAP__ENABLED=false
LDAP__HOST=ldap.example.com
LDAP__PORT=636
LDAP__USESSL=true
LDAP__BASEDN=DC=example,DC=com
LDAP__USERDNTEMPLATE=CN={0},OU=Users,DC=example,DC=com

# Logging
LOGGING__LOGLEVEL__DEFAULT=Information
LOGGING__LOGLEVEL__MICROSOFT_ASPNETCORE=Warning

# Rate Limiting
RATELIMITING__ENABLED=true
RATELIMITING__PERMITLIMIT=200
RATELIMITING__WINDOW=00:01:00

# Health Checks
HEALTHCHECKS__ENABLED=true
HEALTHCHECKS__DATABASECHECKENABLED=true
HEALTHCHECKS__LDAPCHECKENABLED=false

# Security
SECURITY__REQUIREHTTPS=true
SECURITY__STRICTTRANSPORTSECURITYMAXAGE=31536000
SECURITY__ENABLESECURITYHEADERS=true

# Application Environment
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=https://+:443;http://+:80
DOTNET_ENVIRONMENT=Production
