{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "CentralDb": ""
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "hyperv-central",
    "Audience": "hyperv-central-ui",
    "ExpirationMinutes": 480
  },
  "InitialAdmin": {
    "Username": "admin",
    "Password": ""
  },
  "Ldap": {
    "Enabled": false,
    "Host": "",
    "Port": 636,
    "UseSsl": true,
    "BaseDn": "",
    "UserDnTemplate": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "System": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/hyperv-central/central-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 60,
          "fileSizeLimitBytes": 104857600,
          "rollOnFileSizeLimit": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [{SourceContext}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "HyperV.CentralManagement",
      "Environment": "Production"
    }
  },
  "RateLimiting": {
    "Enabled": true,
    "PermitLimit": 200,
    "Window": "00:01:00",
    "QueueLimit": 20
  },
  "HealthChecks": {
    "Enabled": true,
    "DatabaseCheckEnabled": true,
    "LdapCheckEnabled": false
  },
  "Security": {
    "RequireHttps": true,
    "StrictTransportSecurityMaxAge": 31536000,
    "EnableSecurityHeaders": true
  }
}
