{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "CentralDb": "Host=localhost;Port=5432;Database=hyperv_central;Username=hyperv;Password=hyperv"
  },
  "Jwt": {
    "Secret": "change-me-in-production",
    "Issuer": "hyperv-central",
    "Audience": "hyperv-central-ui",
    "ExpirationMinutes": 60
  },
  "InitialAdmin": {
    "Username": "admin",
    "Password": "admin-change-me"
  },
  "Ldap": {
    "Enabled": false,
    "Host": "ldap.example.local",
    "Port": 636,
    "UseSsl": true,
    "BaseDn": "DC=example,DC=local",
    "UserDnTemplate": "CN={0},OU=Users,DC=example,DC=local"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
