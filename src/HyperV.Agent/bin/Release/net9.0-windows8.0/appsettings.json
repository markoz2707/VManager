{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "HyperV.Agent": "Debug"
    },
    "LogToConsole": true,
    "LogToFile": false,
    "LogFilePath": "logs/hyperv-agent.log"
  },
  "Server": {
    "Protocol": "http",
    "Host": "0.0.0.0",
    "Port": 8743,
    "Https": {
      "CertificatePath": "",
      "CertificateKeyPath": "",
      "CertificatePassword": ""
    }
  },
  "Cors": {
    "Hostname": "management.hyperv.local",
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://127.0.0.1:3000",
      "http://localhost:8080",
      "http://127.0.0.1:8080",
      "http://localhost:4200",
      "http://127.0.0.1:4200",
      "http://localhost:8000",
      "http://127.0.0.1:8000"
    ],
    "AllowCredentials": true
  }
}