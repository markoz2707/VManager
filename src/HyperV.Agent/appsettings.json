{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "HyperV.Agent": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/hyperv-agent.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "HyperV.Agent"
    }
  },
  "Server": {
    "Protocol": "http",
    "Host": "0.0.0.0",
    "Port": 8743,
    "Https": {
      "CertificatePath": "",
      "CertificateKeyPath": "",
      "CertificatePassword": ""
    }
  },
  "Cors": {
    "Hostname": "management.hyperv.local",
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://127.0.0.1:3000",
      "http://localhost:8080",
      "http://127.0.0.1:8080",
      "http://localhost:4200",
      "http://127.0.0.1:4200",
      "http://localhost:8000",
      "http://127.0.0.1:8000"
    ],
    "AllowCredentials": true
  },
  "Jwt": {
    "Secret": "your-secret-key-here",
    "Issuer": "hyperv-agent",
    "Audience": "hyperv-client",
    "ExpirationMinutes": 60
  },
  "RateLimiting": {
    "Enabled": true,
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "HealthChecks": {
    "MinimumFreeDiskSpaceMB": 1024
  },
  "Hypervisor": {
    "Type": "auto",
    "KVM": {
      "LibvirtUri": "qemu:///system",
      "DefaultStoragePool": "default",
      "DefaultDiskFormat": "qcow2",
      "DefaultDiskPath": "/var/lib/libvirt/images"
    }
  }
}