{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "HyperV.Agent": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "C:\\ProgramData\\HyperV.Agent\\logs\\hyperv-agent-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 104857600,
          "rollOnFileSizeLimit": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [{SourceContext}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithEnvironmentName" ],
    "Properties": {
      "Application": "HyperV.Agent",
      "Environment": "Production"
    }
  },
  "Server": {
    "Protocol": "https",
    "Host": "0.0.0.0",
    "Port": 8743,
    "Https": {
      "CertificatePath": "/etc/hyperv-agent/certs/agent.crt",
      "CertificateKeyPath": "/etc/hyperv-agent/certs/agent.key",
      "CertificatePassword": ""
    }
  },
  "Cors": {
    "Hostname": "",
    "AllowedOrigins": [],
    "AllowCredentials": true
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "hyperv-agent",
    "Audience": "hyperv-client",
    "ExpirationMinutes": 60
  },
  "RateLimiting": {
    "Enabled": true,
    "PermitLimit": 100,
    "Window": "00:01:00",
    "QueueLimit": 10
  },
  "HealthChecks": {
    "Enabled": true,
    "WmiCheckEnabled": true,
    "HcsCheckEnabled": true,
    "DiskSpaceCheckEnabled": true,
    "MinimumFreeDiskSpaceMB": 1024
  }
}
