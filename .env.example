# HyperV Agent Configuration Template
# Copy this file to .env and fill in your values
# Environment variables override appsettings.json values

# Server Configuration
SERVER__PROTOCOL=https
SERVER__HOST=0.0.0.0
SERVER__PORT=8743

# HTTPS Certificate Paths (for production)
SERVER__HTTPS__CERTIFICATEPATH=/etc/hyperv-agent/certs/agent.crt
SERVER__HTTPS__CERTIFICATEKEYPATH=/etc/hyperv-agent/certs/agent.key
SERVER__HTTPS__CERTIFICATEPASSWORD=

# JWT Configuration
JWT__SECRET=your-strong-secret-key-min-32-chars-here-change-this
JWT__ISSUER=hyperv-agent
JWT__AUDIENCE=hyperv-client
JWT__EXPIRATIONMINUTES=60

# CORS Configuration
CORS__ALLOWEDORIGINS__0=https://central.example.com
CORS__ALLOWEDORIGINS__1=https://management.example.com
CORS__ALLOWCREDENTIALS=true

# Logging
SERILOG__MINIMUMLEVEL__DEFAULT=Information

# Rate Limiting
RATELIMITING__ENABLED=true
RATELIMITING__PERMITLIMIT=100
RATELIMITING__WINDOW=00:01:00

# Health Checks
HEALTHCHECKS__ENABLED=true
HEALTHCHECKS__WMICHECKENABLED=true
HEALTHCHECKS__HCSCHECKENABLED=true
HEALTHCHECKS__DISKSPACECHECKENABLED=true
HEALTHCHECKS__MINIMUMFREEDISKSPACEMB=1024

# Application Environment
ASPNETCORE_ENVIRONMENT=Production
DOTNET_ENVIRONMENT=Production
